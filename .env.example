# Copy this file to `.env` (gitignored) and fill in your provider API keys.
# CLI scripts (pilot.cli.step_0_smoke, pilot.cli.step_2_kvcache, etc.)
# auto-load `.env` at import time. Existing process environment
# variables take precedence — `.env` only fills in missing keys.

# ── Closed answerer slate ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# DashScope: only if you have access (the user's primary path is
# OpenRouter; DashScope is recorded as not_accessible in models.yaml).
DASHSCOPE_API_KEY=

# ── Open-weights via OpenRouter (preferred path) ──────────────────
OPENROUTER_API_KEY=

# ── Optional alternates ───────────────────────────────────────────
# Add only if you want to bypass OpenRouter and hit the underlying
# providers directly. Most workflows do not need these.
GROQ_API_KEY=
DEEPINFRA_API_TOKEN=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
MINIMAX_API_KEY=
