# Copy this file to `.env` (gitignored) and fill in your provider API
# keys. CLI scripts (pilot.cli.step_0_smoke, pilot.cli.step_2_kvcache,
# pilot.data.download, ...) auto-load `.env` at import time and
# `.env` overrides any pre-existing process environment value, so
# rotating a key only requires editing this file rather than
# restarting the shell.

# ── Closed answerer slate ─────────────────────────────────────────
# Anthropic and OpenAI are kept here for reinstateability. Both are
# currently in models.yaml#rejected_candidates after Step 1+2 ruled
# them out (Anthropic on the 30k/min input-token rate-limit; GPT-5.4
# on an account-tier 600k single-call limit). They become slate
# members again on a higher account tier.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Gemini: the SDK accepts either name; the env loader is permissive.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# xAI Grok (full active slate member; cache verification passed).
XAI_API_KEY=

# DashScope: only if you have access (the primary open-weights path
# is OpenRouter; DashScope is recorded as not_accessible in
# models.yaml).
DASHSCOPE_API_KEY=

# ── Open-weights via OpenRouter (preferred path) ──────────────────
# Caching for DeepSeek requires the first-party `deepseek` upstream;
# verify your OpenRouter privacy settings allow it at
# openrouter.ai/settings/privacy.
OPENROUTER_API_KEY=

# ── Dataset acquisition ──────────────────────────────────────────
# NovelQA is a gated HuggingFace dataset. The pilot's env loader
# mirrors HUGGINGFACE_ACCESS_TOKEN into HF_TOKEN at import so the
# HF SDK picks it up. Visit huggingface.co/datasets/NovelQA/NovelQA
# and accept the data-sharing terms with the same HF account whose
# token is set here, then run `make pilot-data-download`.
HUGGINGFACE_ACCESS_TOKEN=

# ── Codabench leaderboard submissions (NovelQA) ───────────────────
# Two paths to authenticate against codabench.org's API. Either is
# enough; pick whichever you prefer. Path A is preferred when cookies
# are convenient; Path B is more convenient day-to-day.
# Path B is verified working against Codabench v1.x as of 2026-05-07.
#
# Path A — paste session cookies from a logged-in browser:
#   1. Log into https://www.codabench.org in your browser.
#   2. Open DevTools → Application → Cookies → www.codabench.org.
#   3. Copy the *values* of `sessionid` and `csrftoken` here.
#   Cookies expire (Codabench's session is ~weeks); refresh as needed.
#   The script tries Path A first if both cookies are set.
CODABENCH_SESSIONID=
CODABENCH_CSRFTOKEN=
#
# Path B — username + password (script logs in via /accounts/login/):
#   The script POSTs to Codabench's login form with the
#   `username` + `password` field names (NOT django-allauth's
#   `login` default — Codabench uses a custom form). On success the
#   sessionid cookie is set and the rest of the API works.
CODABENCH_USERNAME=
CODABENCH_PASSWORD=

# ── Optional alternates ───────────────────────────────────────────
# Add only if you want to bypass OpenRouter and hit the underlying
# providers directly. Most workflows do not need these.
GROQ_API_KEY=
DEEPINFRA_API_TOKEN=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
MINIMAX_API_KEY=
